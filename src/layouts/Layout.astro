---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = "개인 홈페이지",
	description = "Astro로 만든 개인 홈페이지입니다. About, Projects, Posts 페이지로 확장할 수 있는 첫 버전입니다.",
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

const navItems = [
	{ href: "/", label: "Home" },
	{ href: "/about/", label: "About" },
	{ href: "/projects/", label: "Projects" },
	{ href: "/posts/", label: "Posts" },
];

const isCurrent = (href: string) => {
	const itemPath = href.replace(/\/$/, "") || "/";
	return currentPath === itemPath;
};
---

<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<a class="site-name" href="/">Kei</a>
			<nav class="site-nav" aria-label="주요 메뉴">
				{
					navItems.map((item) => (
						<a href={item.href} aria-current={isCurrent(item.href) ? "page" : undefined}>
							{item.label}
						</a>
					))
				}
			</nav>
		</header>

		<main class="site-main">
			<slot />
		</main>

		<footer class="site-footer">
			<p>© Kei. Built with Astro.</p>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		color: #1f2937;
		background: #ffffff;
		font-family:
			"Apple SD Gothic Neo", "Noto Sans KR", Inter, ui-sans-serif, system-ui,
			-apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	body {
		min-height: 100vh;
		margin: 0;
		background: #ffffff;
	}

	a {
		color: #2563eb;
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.18em;
	}

	.site-header,
	.site-main,
	.site-footer {
		width: min(100% - 40px, 1040px);
		margin: 0 auto;
	}

	.site-header {
		display: flex;
		justify-content: space-between;
		gap: 24px;
		align-items: center;
		padding: 36px 0 20px;
	}

	.site-name {
		color: #111827;
		text-decoration: none;
		font-size: 1rem;
		font-weight: 800;
		white-space: nowrap;
	}

	.site-nav {
		display: flex;
		flex-wrap: nowrap;
		gap: 18px;
		align-items: center;
		overflow-x: auto;
		white-space: nowrap;
	}

	.site-nav a {
		color: #4b5563;
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 700;
		padding: 8px 0;
	}

	.site-nav a[aria-current="page"] {
		color: #111827;
		text-decoration: underline;
		text-decoration-thickness: 0.12em;
		text-underline-offset: 0.35em;
	}

	.site-main {
		display: grid;
		gap: 72px;
		padding: 96px 0;
	}

	.site-footer {
		border-top: 1px solid #e5e7eb;
		padding: 28px 0 40px;
	}

	.site-footer p {
		margin: 0;
		color: #6b7280;
		font-size: 0.92rem;
		line-height: 1.7;
	}

	.page-intro {
		max-width: 760px;
	}

	.page-intro h1 {
		margin: 0;
		color: #111827;
		font-size: clamp(2.5rem, 7vw, 5rem);
		line-height: 1.08;
		letter-spacing: 0;
	}

	.page-intro p {
		max-width: 680px;
		margin: 20px 0 0;
		color: #4b5563;
		font-size: 1.1rem;
		line-height: 1.8;
	}

	@media (max-width: 640px) {
		.site-header,
		.site-main,
		.site-footer {
			width: min(100% - 28px, 1040px);
		}

		.site-header {
			align-items: flex-start;
			flex-direction: column;
		}

		.site-main {
			gap: 48px;
			padding: 64px 0 72px;
		}

		.page-intro p {
			font-size: 1rem;
		}
	}
</style>
