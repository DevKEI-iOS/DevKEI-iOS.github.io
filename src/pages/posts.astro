---
import Layout from "../layouts/Layout.astro";
import posts from "../data/posts.json";
---

<Layout
	title="Posts | 개인 홈페이지"
	description="Kei가 배운 것과 경험을 글 중심으로 모아두는 페이지입니다."
>
	<section class="page-intro">
		<h1>Posts</h1>
		<p>
			배운 것과 경험을 글 중심으로 정리하는 공간입니다. 지금 항목은 이번
			수업을 위한 기본 기준이며, 나중에 글의 성격에 맞게 바꿀 수 있습니다.
		</p>
	</section>

	<section class="post-list" aria-label="글 목록">
		{
			posts.map((post) => (
				<article class="post-item">
					<div class="post-meta">
						<time datetime={post.date}>{post.date}</time>
						<span>{post.slug}</span>
					</div>
					<h2>{post.title}</h2>
					<p>{post.summary}</p>
					<ul aria-label={`${post.title} 태그`}>
						{post.tags.map((tag) => (
							<li>{tag}</li>
						))}
					</ul>
				</article>
			))
		}
	</section>
</Layout>

<style>
	.post-list {
		display: grid;
		gap: 22px;
		max-width: 860px;
	}

	.post-item {
		display: grid;
		gap: 14px;
		border-bottom: 1px solid #e5e7eb;
		padding-bottom: 28px;
	}

	.post-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 8px 14px;
		color: #6b7280;
		font-size: 0.92rem;
		font-weight: 700;
	}

	h2,
	p,
	ul {
		margin: 0;
	}

	h2 {
		color: #111827;
		font-size: clamp(1.45rem, 3vw, 2.1rem);
		line-height: 1.3;
		letter-spacing: 0;
	}

	p {
		color: #4b5563;
		font-size: 1.05rem;
		line-height: 1.8;
	}

	ul {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		padding: 0;
		list-style: none;
	}

	li {
		border: 1px solid #e5e7eb;
		border-radius: 999px;
		color: #4b5563;
		font-size: 0.92rem;
		font-weight: 700;
		line-height: 1.4;
		padding: 5px 10px;
	}

	@media (max-width: 640px) {
		p {
			font-size: 1rem;
		}
	}
</style>
