---
import Layout from "../../layouts/Layout.astro";
import projects from "../../data/projects.json";

const project = projects.find((item) => item.slug === "pangyo-translator");

if (!project) {
	throw new Error("Project not found: pangyo-translator");
}
---

<Layout title={`${project.title} | Projects`} description={project.description}>
	<section class="project-detail">
		<a class="back-link" href="/projects/">Projects로 돌아가기</a>
		<p class="section-label">Project Detail</p>
		<h1>{project.title}</h1>
		<p class="description">{project.description}</p>

		<section aria-labelledby="background-title">
			<h2 id="background-title">프로젝트 배경</h2>
			<p>{project.detail}</p>
		</section>

		<section aria-labelledby="role-title">
			<h2 id="role-title">내가 한 일</h2>
			<p>{project.role}</p>
		</section>

		<section aria-labelledby="tools-title">
			<h2 id="tools-title">사용 도구</h2>
			<ul>
				{project.tools.map((tool) => <li>{tool}</li>)}
			</ul>
		</section>

		<section aria-labelledby="result-title">
			<h2 id="result-title">결과 또는 배운 점</h2>
			<p>{project.result}</p>
		</section>
	</section>
</Layout>

<style>
	.project-detail {
		display: grid;
		gap: 36px;
		max-width: 820px;
	}

	.back-link {
		justify-self: start;
		color: #4b5563;
		font-weight: 800;
	}

	.section-label {
		margin: 0;
		color: #2563eb;
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	h1,
	h2,
	p,
	ul {
		margin: 0;
	}

	h1 {
		color: #111827;
		font-size: clamp(2.5rem, 7vw, 5rem);
		line-height: 1.08;
		letter-spacing: 0;
	}

	h2 {
		color: #111827;
		font-size: clamp(1.35rem, 3vw, 2rem);
		line-height: 1.25;
		letter-spacing: 0;
	}

	.description,
	p,
	li {
		color: #4b5563;
		font-size: 1.05rem;
		line-height: 1.85;
	}

	section {
		display: grid;
		gap: 14px;
	}

	ul {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		padding: 0;
		list-style: none;
	}

	li {
		border: 1px solid #e5e7eb;
		border-radius: 999px;
		padding: 6px 12px;
	}
</style>
