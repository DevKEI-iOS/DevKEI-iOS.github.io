---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import projects from "../data/projects.json";
---

<Layout
	title="Projects | 개인 홈페이지"
	description="Kei가 기획하고 설계한 프로젝트를 모아둔 페이지입니다."
>
	<section class="page-intro">
		<h1>Projects</h1>
		<p>
			제가 기획하거나 설계한 프로젝트를 모아둔 공간입니다. 카드 항목은 이번
			수업을 위한 기준이며, 나중에 홈페이지 방향에 맞게 바꿀 수 있습니다.
		</p>
	</section>

	<section class="project-list" aria-label="프로젝트 목록">
		{projects.map((project) => <ProjectCard project={project} />)}
	</section>
</Layout>

<style>
	.project-list {
		display: grid;
		gap: 24px;
	}
</style>
